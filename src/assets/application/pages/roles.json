        },
        {
          "name": "tenantName",
          "label": "Tenant",
          "type": "select",
          "placeholder": "Select Tenant",
          "options": [],
          "required": true,
          "colSpan": "col-1"
        },
        {
          "name": "description",
          "label": "Description",
          "type": "textarea",
          "placeholder": "Describe this role's responsibilities",
          "colSpan": "col-3"
        },
        {
          "sectionName": "Role Type",
          "name": "_s1",
          "label": "",
          "type": "hidden"
        },
        {
          "name": "roleType",
          "label": "Role Type",
          "type": "select",
          "options": [
            {
              "label": "System Admin",
              "value": "SYSTEM_ADMIN"
            },
            {
              "label": "Approver",
              "value": "APPROVER"
            },
            {
              "label": "Requester",
              "value": "REQUESTER"
            },
            {
              "label": "Viewer",
              "value": "VIEWER"
            }
          ],
          "required": true,
          "colSpan": "col-1"
        },
        {
          "name": "status",
          "label": "Status",
          "type": "select",
          "options": [
            {
              "label": "Active",
              "value": "ACTIVE"
            },
            {
              "label": "Inactive",
              "value": "INACTIVE"
            }
          ],
          "colSpan": "col-1"
        }
      ]
    },
    {
      "stepName": "step2",
      "label": "Role Action Permissions",
      "index": 2,
      "fields": [
        {
          "name": "actions",
          "label": "Action Permissions",
          "type": "roleActions",
          "colSpan": "col-3"
        }
