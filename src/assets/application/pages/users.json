          "colSpan": "col-1"
        },
        {
          "sectionName": "Contact",
          "name": "_s2",
          "label": "",
          "type": "hidden"
        },
        {
          "name": "email",
          "label": "Email",
          "type": "input",
          "inputType": "email",
          "required": true,
          "placeholder": "user@example.com",
          "colSpan": "col-1"
        },
        {
          "name": "contactNumber",
          "label": "Contact Number",
          "type": "input",
          "inputType": "text",
          "placeholder": "+1 555 000 0000",
          "colSpan": "col-1"
        },
        {
          "sectionName": "Access",
          "name": "_s3",
          "label": "",
          "type": "hidden"
        },
        {
          "name": "role",
          "label": "Role",
          "type": "select",
          "options": [
            {
              "label": "System Admin",
              "value": "SYSTEM_ADMIN"
            },
            {
              "label": "Approver",
              "value": "APPROVER"
            },
            {
              "label": "Requester",
              "value": "REQUESTER"
            },
            {
              "label": "Viewer",
              "value": "VIEWER"
            }
          ],
          "required": true,
          "colSpan": "col-1"
        },
        {
          "name": "tenantName",
          "label": "Tenant",
          "type": "select",
          "placeholder": "Select Tenant",
          "options": [],
          "required": true,
          "colSpan": "col-1"
        },
        {
          "name": "status",
          "label": "Status",
          "type": "select",
          "options": [
            {
              "label": "Active",
              "value": "ACTIVE"
            },
            {
              "label": "Inactive",
              "value": "INACTIVE"
            }
          ],
          "colSpan": "col-1"
        }
      ]
