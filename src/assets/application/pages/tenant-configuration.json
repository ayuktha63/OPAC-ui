    {"name": "configValue", "label": "Config Value", "isHeaderView": true, "columnView": true},
    {"name": "category",    "label": "Category",     "isHeaderView": true, "columnView": true},
    {"name": "status",      "label": "Status",       "isHeaderView": true, "columnView": true, "pipe": "status"},
